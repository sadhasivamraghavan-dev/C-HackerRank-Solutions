#include <iostream>
#include <string>
#include <sstream>
#include <exception>

// Define the exception here
class BadLengthException : public std::exception {
private:
    std::string msg;

public:
    // Constructor that accepts the length of the invalid username
    BadLengthException(int length) : msg(std::to_string(length)) {}

    // Override the what() method to return the length as a const char*
    virtual const char* what() const noexcept override {
        return msg.c_str();
    }
};
