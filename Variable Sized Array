#include <iostream>
#include <vector>
#include <algorithm>

using namespace std;

int main() {
    /* Enter your code here. Read input from STDIN. Print output to STDOUT */   
    int n; // number of arrays
    int q; // number of queries
    cin >> n >> q;

    // Create a vector of vectors to store the variable-length arrays
    vector<vector<int>> arrays(n);

    // Read the variable-length arrays
    for (int i = 0; i < n; i++) {
        int len; // length of the i-th array
        cin >> len;
        arrays[i].resize(len); // Resize the inner vector to the specified length

        for (int j = 0; j < len; j++) {
            cin >> arrays[i][j]; // Read the elements
        }
    }

    // Process queries and print the results
    for (int k = 0; k < q; k++) {
        int arrayIndex;
        int elementIndex;
        cin >> arrayIndex >> elementIndex;
        // Access and print the requested element
        cout << arrays[arrayIndex][elementIndex] << endl;
    }

    return 0;
}
